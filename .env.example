# RPD Internal Ops — environment variables
# Copy to .env.local for development. NEVER commit a real .env*.
# In production, materialize as /srv/rpd-ops/.env.production owned by root, mode 0640.

# ── Runtime ────────────────────────────────────────────────────────
NODE_ENV=development

# ── Auth.js (next-auth) ────────────────────────────────────────────
# Public URL the app is served from. In production, the HTTPS hostname.
NEXTAUTH_URL=http://localhost:3000
# 32+ bytes. Generate: openssl rand -base64 48
NEXTAUTH_SECRET=replace-me-32-or-more-random-bytes

# ── Database ───────────────────────────────────────────────────────
# In dev: docker compose brings up Postgres on the internal network.
# In prod: db service is reachable only from the app container on the
# Docker network — never publish 5432.
DATABASE_URL=postgresql://rpdops:rpdops_dev_pw@db:5432/rpdops?schema=public

# ── Application encryption ────────────────────────────────────────
# 32 bytes. Generate: openssl rand -base64 32
# Used for envelope encryption of User.mfaSecret. Rotation requires re-encrypt.
MFA_ENCRYPTION_KEY=replace-me-32-bytes-base64

# ── Session policy (ms) ───────────────────────────────────────────
SESSION_IDLE_MS=1800000
SESSION_ABSOLUTE_MS=43200000

# ── Rate limits ───────────────────────────────────────────────────
# Auth endpoints, per-IP, per-minute.
RATE_LIMIT_AUTH_PER_MIN=10
# General write endpoints, per-user, per-minute.
RATE_LIMIT_WRITE_PER_MIN=120

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Trusted proxy ─────────────────────────────────────────────────
# When running behind Caddy/Nginx, set this to 1 so the app trusts the
# X-Forwarded-For / X-Forwarded-Proto headers from the proxy.
# In raw dev (no proxy), leave at 0.
TRUST_PROXY=0
